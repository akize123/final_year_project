/* Student Dashboard Design System — white / light blue palette */

:root {
  --ds-shell-bg: #f0f2f8;
  --ds-sidebar-bg: #003566;
  --ds-auca-blue: #003566;
  --ds-sidebar-border: #2d6a9f;
  --ds-sidebar-border-hover: #4a8fc4;
  --ds-content-bg: #ffffff;
  --ds-card-bg: #ffffff;
  --ds-accent: #0066cc;
  --ds-accent-light: #e8f2fc;
  --ds-text-primary: #1a1d2e;
  --ds-text-secondary: #8a8fa8;
  --ds-border: #e8eaf2;
  --ds-row-hover: #f7f8fd;
  --ds-input-bg: #f7f8fd;
  --ds-chart-secondary: #d0d4f7;
  --ds-sidebar-width: 280px;
  --ds-navbar-height: 56px;
}

/* App shell */
.ds-app-shell {
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  background: var(--ds-shell-bg);
  font-family: "Inter", "Plus Jakarta Sans", system-ui, sans-serif;
  color: var(--ds-text-primary);
}

/* Top navbar */
.ds-top-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  height: var(--ds-navbar-height);
  background: #ffffff;
  border-bottom: 1px solid var(--ds-border);
  display: flex;
  align-items: center;
  padding: 0 20px;
  gap: 18px;
}

.ds-brand {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 18px;
  font-weight: 700;
  color: var(--ds-accent);
  white-space: nowrap;
  flex-shrink: 0;
}

.ds-brand-logo {
  width: 36px;
  height: 36px;
  object-fit: contain;
}

.ds-student-layout .ds-top-navbar-student {
  left: var(--ds-sidebar-width);
  background: var(--ds-auca-blue);
  border-bottom: 1px solid rgba(255, 255, 255, 0.16);
  box-shadow: 0 8px 24px rgba(29, 53, 87, 0.16);
}

.ds-student-layout .ds-main-content {
  margin-top: var(--ds-navbar-height);
}

.ds-search-wrap {
  flex: 1;
  max-width: 480px;
  margin: 0 auto;
}

.ds-search-input {
  width: 100%;
  border: none;
  border-radius: 999px;
  background: var(--ds-shell-bg);
  padding: 8px 18px;
  font-size: 14px;
  color: var(--ds-text-primary);
  outline: none;
}

.ds-search-input::placeholder {
  color: var(--ds-text-secondary);
}

.ds-navbar-right {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
  margin-left: auto;
}

.ds-notification-btn {
  position: relative;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  color: var(--ds-text-secondary);
}

.ds-notification-btn:hover {
  color: var(--ds-text-primary);
}

.ds-notification-badge {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 8px;
  height: 8px;
  background: #dc3545;
  border-radius: 50%;
  border: 2px solid #fff;
}

.ds-user-menu {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  border: none;
  background: none;
  padding: 3px 8px;
  border-radius: 8px;
}

.ds-user-menu:hover {
  background: var(--ds-row-hover);
}

.ds-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--ds-accent-light);
  color: var(--ds-accent);
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ds-user-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--ds-text-primary);
}

.ds-caret {
  font-size: 10px;
  color: var(--ds-text-secondary);
}

.ds-student-layout .ds-user-menu {
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  padding: 6px 10px;
  border-radius: 999px;
  box-shadow: none;
}

.ds-student-layout .ds-user-menu:hover {
  background: rgba(255, 255, 255, 0.22);
}

.ds-student-layout .ds-avatar {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.ds-student-layout .ds-user-name,
.ds-student-layout .ds-caret {
  color: #ffffff;
}

.ds-student-layout .ds-search-input {
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
}

.ds-student-layout .ds-search-input::placeholder {
  color: rgba(255, 255, 255, 0.72);
}

.ds-student-layout .ds-notification-btn {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 999px;
}

.ds-student-layout .ds-notification-btn:hover {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
}

.ds-student-layout .ds-notification-badge {
  border-color: var(--ds-auca-blue);
}

/* Layout body */
.ds-layout-body {
  display: flex;
  padding-top: var(--ds-navbar-height);
  height: 100vh;
  min-height: 0;
  overflow: hidden;
}

/* Sidebar — solid AUCA blue, full height to logo */
.ds-sidebar {
  position: fixed;
  top: 0;
  left: 0;
  width: var(--ds-sidebar-width);
  height: 100vh;
  background: var(--ds-auca-blue);
  border-right: 1px solid rgba(255, 255, 255, 0.12);
  overflow: hidden;
  z-index: 50;
  display: flex;
  flex-direction: column;
}

.ds-sidebar-brand {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 12px 12px 10px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.22);
}

.ds-sidebar-logo {
  width: 64px;
  height: 64px;
  object-fit: contain;
  border-radius: 50%;
  background: #ffffff;
  padding: 4px;
}

.ds-sidebar-brand-name {
  font-size: 14px;
  font-weight: 800;
  letter-spacing: 0.12em;
  color: #ffffff;
  text-align: center;
  line-height: 1.3;
}

.ds-sidebar-fm .ds-sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 8px 10px 10px;
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.25) transparent;
}

.ds-sidebar-fm .ds-sidebar-nav::-webkit-scrollbar {
  width: 4px;
}

.ds-sidebar-fm .ds-sidebar-nav::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.25);
  border-radius: 4px;
}

.ds-fm-nav-card {
  display: flex;
  align-items: center;
  gap: 10px;
  min-height: 36px;
  padding: 8px 12px;
  border-radius: 10px;
  text-decoration: none;
  background: transparent;
  border: 1.5px solid var(--ds-sidebar-border);
  box-shadow: none;
  transition: background 0.15s, border-color 0.15s;
  flex-shrink: 0;
}

.ds-fm-nav-toggle {
  width: 100%;
  color: #ffffff;
  cursor: pointer;
}

.ds-fm-nav-card span {
  font-size: 14px;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
}

.ds-fm-toggle-caret {
  margin-left: auto;
  opacity: 0.8;
  transition: transform 0.15s ease;
}

.ds-fm-toggle-caret.open {
  transform: rotate(180deg);
}

.ds-fm-nav-card:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: var(--ds-sidebar-border-hover);
}

.ds-fm-nav-card.active {
  background: rgba(0, 0, 0, 0.15);
  border-color: #ffffff;
  box-shadow: none;
}

.ds-fm-nav-card.doc {
  padding: 7px 10px;
  border-radius: 10px;
}

.ds-fm-nav-card.doc span {
  font-size: 14px;
  font-weight: 700;
}

.ds-fm-nav-card.wide {
  grid-column: 1 / -1;
}

.ds-fm-icon {
  flex-shrink: 0;
}

.ds-fm-section-label {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.72);
  padding: 8px 4px 3px;
  flex-shrink: 0;
}

.ds-fm-doc-grid {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex-shrink: 0;
}

.ds-fm-subnav {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding-left: 12px;
  flex-shrink: 0;
}

.ds-fm-subnav .ds-fm-nav-card {
  min-height: 31px;
  padding: 6px 10px;
  border-color: rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.04);
}

.ds-fm-subnav .ds-fm-nav-card span {
  font-size: 13px;
  font-weight: 650;
}

/* Legacy aliases — remove old styles */
.ds-fm-link,
.ds-fm-doc-card {
  display: none;
}

.ds-sidebar-group-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--ds-text-secondary);
  padding: 12px 20px 6px;
}

.ds-nav-item {
  display: block;
  padding: 10px 20px;
  font-size: 14px;
  color: var(--ds-text-primary);
  text-decoration: none;
  border-left: 3px solid transparent;
  transition: background 0.15s;
}

.ds-nav-item:hover {
  background: var(--ds-row-hover);
  color: var(--ds-text-primary);
}

.ds-nav-item.active {
  background: var(--ds-accent-light);
  color: var(--ds-accent);
  border-left-color: var(--ds-accent);
  font-weight: 600;
}

/* Tree children — always visible, indented */
.ds-nav-tree-parent {
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 600;
  color: var(--ds-text-primary);
}

.ds-nav-tree-children {
  padding-left: 8px;
}

.ds-nav-tree-child {
  display: block;
  padding: 8px 20px 8px 28px;
  font-size: 13px;
  color: var(--ds-text-primary);
  text-decoration: none;
  border-left: 3px solid transparent;
}

.ds-nav-tree-child:hover {
  background: var(--ds-row-hover);
}

.ds-nav-tree-child.active {
  background: var(--ds-accent-light);
  color: var(--ds-accent);
  border-left-color: var(--ds-accent);
  font-weight: 600;
}

/* Main content — paginated pages avoid body scroll */
.ds-main-content {
  flex: 1;
  margin-left: var(--ds-sidebar-width);
  background: var(--ds-content-bg);
  height: calc(100vh - var(--ds-navbar-height));
  overflow-y: auto;
  overflow-x: hidden;
  padding: 28px 32px;
  box-sizing: border-box;
}

.ds-student-layout .ds-main-content {
  overflow-y: hidden;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.ds-student-layout .ds-main-content::-webkit-scrollbar {
  width: 0;
  height: 0;
}

.ds-page-frame {
  max-height: calc(100vh - var(--ds-navbar-height) - 56px);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Non-table pages: content scrolls via main area */
.ds-page-scroll {
  padding-bottom: 40px;
}

.ds-page-frame-scroll-section {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

@media (max-width: 991px) {
  .ds-sidebar {
    transform: translateX(-100%);
  }
  .ds-sidebar.open {
    transform: translateX(0);
  }
  .ds-main-content {
    margin-left: 0;
  }
}

/* Page header */
.page-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 24px;
}

.page-header-aside {
  flex-shrink: 0;
  text-align: right;
}

.page-header-centered {
  justify-content: center;
  text-align: center;
}

.page-header-centered .page-title {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 6px;
  background: #1d3557;
  color: #ffffff;
  font-size: 16px;
  box-shadow: 0 4px 6px rgba(29, 53, 87, 0.12);
}

.ds-schedule-page {
  margin-top: -18px;
}

.ds-schedule-page .page-header {
  margin-bottom: 14px;
}

.page-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--ds-text-primary);
  margin: 0;
}

.ds-dashboard-welcome {
  display: block;
  color: var(--ds-text-secondary);
  font-size: 14px;
  font-weight: 800;
  line-height: 1.4;
  padding-top: 3px;
}

/* Cards */
.ds-card {
  background: var(--ds-card-bg);
  border: 1px solid var(--ds-border);
  border-radius: 14px;
  padding: 24px;
  box-shadow: 0 2px 8px rgba(91, 108, 249, 0.06);
}

.ds-card-compact {
  padding: 18px;
  border-radius: 12px;
}

.ds-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.ds-card-compact .ds-card-header {
  margin-bottom: 12px;
}

.ds-card-compact .ds-card-label {
  font-size: 11px;
}

.ds-card-compact .ds-card-link {
  font-size: 12px;
}

.ds-card-label {
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  color: var(--ds-text-secondary);
  letter-spacing: 0.5px;
}

.ds-card-link {
  font-size: 13px;
  color: var(--ds-accent);
  text-decoration: none;
}

.ds-card-link-button {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  font: inherit;
}

.ds-card-link:hover {
  text-decoration: underline;
}

.ds-section-heading {
  font-size: 15px;
  font-weight: 600;
  color: var(--ds-text-primary);
  margin: 0 0 12px;
}

/* KPI */
.ds-kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 20px;
  margin-bottom: 24px;
}

.ds-kpi-card {
  background: var(--ds-card-bg);
  border: 1px solid var(--ds-border);
  border-radius: 14px;
  padding: 24px;
  box-shadow: 0 2px 8px rgba(91, 108, 249, 0.06);
}

.ds-kpi-label {
  font-size: 12px;
  color: var(--ds-text-secondary);
  margin-bottom: 8px;
}

.ds-kpi-value {
  font-size: 28px;
  font-weight: 700;
  color: var(--ds-text-primary);
  line-height: 1.2;
}

.ds-kpi-trend {
  font-size: 12px;
  font-weight: 600;
  margin-top: 6px;
}

.ds-kpi-trend.up {
  color: #198754;
}

.ds-kpi-trend.down {
  color: #dc3545;
}

.ds-kpi-sub {
  font-size: 12px;
  color: var(--ds-text-secondary);
  margin-top: 4px;
}

/* Card grid */
.ds-card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}

/* Attendance — connected full-width chart pair */
.ds-attendance-charts-connected {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  margin-bottom: 20px;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid var(--ds-border);
  box-shadow: 0 2px 12px rgba(91, 108, 249, 0.08);
  min-height: 360px;
}

.ds-attendance-charts-connected .ds-attendance-chart-panel {
  border: none;
  border-radius: 0;
  box-shadow: none;
  margin: 0;
  display: flex;
  flex-direction: column;
  min-height: 360px;
}

.ds-attendance-charts-connected .ds-attendance-chart-panel:first-child {
  border-right: 1px solid var(--ds-border);
}

.ds-attendance-chart-area {
  flex: 1;
  min-height: 300px;
  width: 100%;
}

@media (max-width: 991px) {
  .ds-card-grid,
  .ds-kpi-grid {
    grid-template-columns: 1fr;
  }

  .ds-attendance-charts-connected {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .ds-attendance-charts-connected .ds-attendance-chart-panel {
    min-height: 320px;
  }

  .ds-attendance-charts-connected .ds-attendance-chart-panel:first-child {
    border-right: none;
    border-bottom: 1px solid var(--ds-border);
  }
}

/* Tables */
.ds-table-wrap {
  overflow-x: auto;
  border-radius: 14px;
}

.ds-table {
  width: 100%;
